modules = ["nodejs-24", "python-3.11", "dotnet-9.0"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "srt-lab-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "unlock-catalog-check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "asset-sweep-check"

[[workflows.workflow]]
name = "srt-lab-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/srt-lab test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "unlock-catalog-check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 tools/python-bridge/tools/srtlab_unlock_catalog_gen.py --check && node artifacts/srt-lab/scripts/copy-unlock-catalog.mjs --check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "asset-sweep-check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm sweep:assets:check"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 25456
externalPort = 3000

[[ports]]
localPort = 25457
externalPort = 3002

[nix]
channel = "stable-25_05"
