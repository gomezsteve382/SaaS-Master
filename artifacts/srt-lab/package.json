{
  "name": "@workspace/srt-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "prebuild": "node scripts/update-manifest.mjs && node scripts/generate-quickref-data.mjs && node scripts/extract-alfaobd.mjs && node scripts/extract-alfaobd-algorithms.mjs",
    "predev": "node scripts/generate-quickref-data.mjs && node scripts/extract-alfaobd.mjs && node scripts/extract-alfaobd-algorithms.mjs",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "manifest:update": "node scripts/update-manifest.mjs",
    "manifest:check": "node scripts/update-manifest.mjs --check",
    "manifest:bump": "node scripts/update-manifest.mjs --bump",
    "quickref:gen": "node scripts/generate-quickref-data.mjs",
    "quickref:check": "node scripts/generate-quickref-data.mjs --check",
    "codegen:alfaobd": "node scripts/extract-alfaobd.mjs",
    "codegen:alfaobd:check": "node scripts/extract-alfaobd.mjs --check",
    "codegen:alfaobd-algos": "node scripts/extract-alfaobd-algorithms.mjs",
    "codegen:alfaobd-algos:check": "node scripts/extract-alfaobd-algorithms.mjs --check",
    "test": "vitest run --config vitest.config.ts && node --test src/__tests__/*.test.mjs",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.4"
  }
}
