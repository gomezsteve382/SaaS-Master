@@ -157,4 +162,23 @@ describe('gpec2aUnlocker fixture — INT_FLASH locked (4 MB)', () => {
     expect(r.patched[UNLOCK_FLAG_OFFSET]).toBe(UNLOCK_FLAG_BYTE);
