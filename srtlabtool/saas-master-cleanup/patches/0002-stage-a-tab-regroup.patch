From adcfec34cc3f7ae3e2e98f76dd06065428db25ab Mon Sep 17 00:00:00 2001
From: srtlab <gomezsteve1379@gmail.com>
Date: Thu, 11 Jun 2026 04:09:43 +0000
Subject: [PATCH] Stage A: regroup the 51-tab drawer into 6 categories
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replace the drawer's 5 ad-hoc categories (PROGRAM/LIVE/ANALYZE/TOOLS/
RESEARCH) with 6 workflow groups: MODULES, MARRY & KEYS, FLASH & FIRMWARE,
LIVE & DIAGNOSTICS, DATA & WORKFLOW, INTEL & REFERENCE. Rebuild
WORKSPACE_CATEGORIES so every non-primary tab is assigned (the drawer drops
any uncategorized tab, so this also closes a latent 'unreachable tab' trap).

Front-page rail (PRIMARY_NAV) and all tab behavior unchanged — organization
only. Verified: 51 tabs, all reachable, categories valid, sections aligned.
---
 artifacts/srt-lab/src/App.jsx                 | 40 ++++++++++---------
 .../srt-lab/src/components/CommandShell.jsx   | 13 +++---
 2 files changed, 28 insertions(+), 25 deletions(-)

diff --git a/artifacts/srt-lab/src/App.jsx b/artifacts/srt-lab/src/App.jsx
index 8d8902e..7433d7c 100644
--- a/artifacts/srt-lab/src/App.jsx
+++ b/artifacts/srt-lab/src/App.jsx
@@ -984,26 +984,28 @@ const WORKSPACE_TABS = [
   // any later duplicates so the sidebar renders one button per id.
   .filter((t, i, a) => a.findIndex(x => x.id === t.id) === i);
 
-/* Maps every workspace tab id to one of five sidebar categories.
- * INFO is intentionally absent — it lives in the reference panel. */
+/* Maps every workspace tab id to one of six drawer groups. Every non-primary
+ * tab MUST appear here — the drawer drops any tab without a category
+ * (CommandShell AdvancedDrawer), so an omission makes a tab unreachable.
+ * INFO is intentionally absent — it lives in the reference panel, not the drawer. */
