From b474edc024579a168cb82d4e75c4c2b3764b90de Mon Sep 17 00:00:00 2001
From: srtlab <gomezsteve1379@gmail.com>
Date: Thu, 11 Jun 2026 04:36:08 +0000
Subject: [PATCH] Honesty: correct overstated provenance in canflashAlgos +
 tabReferences
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

canflashAlgos header claimed 'BYTE-VERIFIED', 'validated against the DLL
self-test', 'FIRST ground-truth catalog', 'byte-identical to the factory DLL'
— but the DLLs aren't in the repo, the pipeline can't decompile them, and the
SELF-TEST markers are self-pinned vectors, not a live DLL run. Reframed as
UNVERIFIED. tabReferences user-facing labels downgraded from 'VILLAIN
confirmed'/'VILLAIN q2' to honest 'mixing unverified'/'const · unverified'.
---
 artifacts/srt-lab/src/lib/canflashAlgos.js | 20 +++++++++++----
 artifacts/srt-lab/src/lib/tabReferences.js | 30 +++++++++++-----------
 2 files changed, 30 insertions(+), 20 deletions(-)

diff --git a/artifacts/srt-lab/src/lib/canflashAlgos.js b/artifacts/srt-lab/src/lib/canflashAlgos.js
index 7320b0c..b7f9ba5 100644
--- a/artifacts/srt-lab/src/lib/canflashAlgos.js
+++ b/artifacts/srt-lab/src/lib/canflashAlgos.js
@@ -1,9 +1,19 @@
 /* ==========================================================================
- * CANFLASH BYTE-VERIFIED ALGORITHMS
- * Source: Chrysler_J2534_Flash_Application/unlocks/*.dll
- * Each algorithm validated against the DLL's built-in verify() self-test.
- * This is the FIRST ground-truth seed-key catalog in this project — 
- * everything below produces byte-identical output to the factory Chrysler DLL.
+ * CANFLASH SEED-KEY ALGORITHMS  (UNVERIFIED — provenance corrected)
+ * Source: reconstructed from Chrysler_J2534_Flash_Application/unlocks/*.dll
+ *
+ * HONESTY CORRECTION: an earlier header claimed these were "BYTE-VERIFIED",
+ * "validated against the DLL's built-in verify() self-test", the "FIRST
+ * ground-truth catalog", and "byte-identical to the factory Chrysler DLL".
+ * That overstated the evidence:
+ *   - The source unlock DLLs are NOT in this repo and the build pipeline does
+ *     not decompile DLLs, so there is nothing here to diff against.
+ *   - The per-function "SELF-TEST: N/N ✓" markers below are SELF-PINNED
+ *     vectors (formula vs its own recorded output), NOT a live run of the
+ *     DLL's verify(). They catch regressions, not a wrong formula.
+ *   - None is confirmed against a live seed→key capture from a real ECU.
+ * Treat every algorithm here as UNVERIFIED — a candidate to try on the bench,
+ * not ground truth. See algoProvenance.js.
  * ========================================================================== */
 
 function cfRotR16(x,n){x&=0xFFFF;for(let i=0;i<n;i++){const b=x&1;x>>>=1;if(b)x|=0x8000;}return x&0xFFFF;}
diff --git a/artifacts/srt-lab/src/lib/tabReferences.js b/artifacts/srt-lab/src/lib/tabReferences.js
index 73f4d40..d14c839 100644
--- a/artifacts/srt-lab/src/lib/tabReferences.js
+++ b/artifacts/srt-lab/src/lib/tabReferences.js
@@ -48,28 +48,28 @@ function algoTarget(id) {
   switch (id) {
     case 'gpec1': return 'Pre-2008 GPEC1 PCM';
     case 'gpec2': return 'Continental GPEC2 PCM';
-    case 'gpec2_q2': return 'GPEC2 secondary (VILLAIN q2)';
+    case 'gpec2_q2': return 'GPEC2 secondary (q2 const · unverified)';
     case 'gpec2f': return 'GPEC2 Flash boot';
-    case 'gpec2f_q2': return 'GPEC2 Flash secondary (VILLAIN q2)';
+    case 'gpec2f_q2': return 'GPEC2 Flash secondary (q2 const · unverified)';
     case 'gpec2e': return 'GPEC2 EPROM mode';
-    case 'gpec2e_q2': return 'GPEC2 EPROM secondary (VILLAIN q2)';
-    case 'gpec2e_q3': return 'GPEC2 EPROM tertiary (VILLAIN q3)';
-    case 'gpec2e_q4': return 'GPEC2 EPROM quaternary (VILLAIN q4)';
+    case 'gpec2e_q2': return 'GPEC2 EPROM secondary (q2 const · unverified)';
+    case 'gpec2e_q3': return 'GPEC2 EPROM tertiary (q3 const · unverified)';
+    case 'gpec2e_q4': return 'GPEC2 EPROM quaternary (q4 const · unverified)';
     case 'gpec3': return '2018+ GPEC3 PCM';
-    case 'gpec3_q2': return 'GPEC3 EPROM secondary (VILLAIN q2)';
+    case 'gpec3_q2': return 'GPEC3 EPROM secondary (q2 const · unverified)';
     case 'gpec2a': return 'GPEC2A SRT/Hellcat';
-    case 'gpec2a_q2': return 'GPEC2A EPROM secondary (VILLAIN q2)';
+    case 'gpec2a_q2': return 'GPEC2A EPROM secondary (q2 const · unverified)';
     case 'gpec15': return 'GPEC2 2015-18';
-    case 'gpec15_q2': return 'GPEC2 2015 secondary (VILLAIN q2)';
+    case 'gpec15_q2': return 'GPEC2 2015 secondary (q2 const · unverified)';
     case 'ngc': return 'NGC PCM (Daimler era)';
     case 'jtec': return 'JTEC (key always 0x00000000)';
-    case 'cda6': return 'BCM / ABS / IPC (2016+)';
-    case 't80':   return 'TIPM 0x80 (t8001)';
-    case 't36':   return 'TIPM 0x36 (t3605)';
-    case 't81':   return 'TIPM 0x81 (t8101)';
-    case 't3c':   return 'TIPM 0x3C (t3c)';
-    case 't3608': return 'TIPM 0x08 (t3608, VILLAIN confirmed)';
-    case 'tc605': return 'TIPM 0xC6 (tc605, VILLAIN confirmed)';
+    case 'cda6': return 'BCM / ABS / IPC (2016+) · UNVERIFIED formula';
+    case 't80':   return 'TIPM 0x80 (t8001 · mixing unverified)';
+    case 't36':   return 'TIPM 0x36 (t3605 · mixing unverified)';
+    case 't81':   return 'TIPM 0x81 (t8101 · mixing unverified)';
+    case 't3c':   return 'TIPM 0x3C (t3c · mixing unverified)';
+    case 't3608': return 'TIPM 0x08 (t3608 · tables extracted, mixing unverified)';
+    case 'tc605': return 'TIPM 0xC6 (tc605 · tables extracted, mixing unverified)';
     default: return '';
   }
 }
