auto-install-peers=false
strict-peer-dependencies=false
# OneDrive (and any sync client that doesn't preserve symlinks) strips pnpm's
# symlinked node_modules, which silently breaks every @workspace/* import and the
# .bin shims. node-linker=hoisted makes pnpm COPY packages into a flat
# node_modules instead of symlinking, so the install survives a sync round-trip.
# Trade-off: more disk + a fuller node_modules; worth it on this OneDrive checkout.
node-linker=hoisted
